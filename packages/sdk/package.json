{
  "name": "@centient/sdk",
  "version": "1.3.0",
  "description": "TypeScript SDK for Engram Memory Server",
  "repository": {
    "type": "git",
    "url": "https://github.com/centient-labs/engram-sdk",
    "directory": "packages/sdk"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run --config vitest.all.config.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "engram",
    "sdk",
    "typescript",
    "memory",
    "ai-agents",
    "qdrant",
    "embeddings"
  ],
  "author": "Owen Johnson",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
