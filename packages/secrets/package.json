{
  "name": "@centient/secrets",
  "version": "0.1.0",
  "description": "Cross-platform secrets vault with AES-256-GCM encryption and platform-native key storage",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.17"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
